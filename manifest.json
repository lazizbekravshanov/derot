{
  "manifest_version": 3,
  "name": "derot — Focus & Deep Work",
  "version": "1.0.0",
  "description": "Block distractions and stay focused with site blocking, pomodoro timer, and productivity analytics.",
  "permissions": ["storage", "tabs", "alarms", "webNavigation", "notifications", "idle"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "pages/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "commands": {
    "toggle-focus": {
      "suggested_key": { "default": "Alt+Shift+F" },
      "description": "Toggle focus mode"
    }
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["pages/*", "styles/*", "scripts/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
